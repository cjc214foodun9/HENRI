{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AccessibilityTree",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "focus_state": {
            "type": "boolean"
          },
          "wcag_metadata": {
            "type": "object",
            "properties": {
              "labeled_by": {
                "type": "string"
              },
              "described_by": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "invalid": {
                "type": "boolean"
              },
              "alt_text": {
                "type": "string"
              }
            },
            "required": [
              "labeled_by",
              "described_by",
              "required",
              "invalid",
              "alt_text"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "role",
          "name",
          "value",
          "focus_state",
          "wcag_metadata"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "title",
    "nodes"
  ],
  "additionalProperties": false
}
